/**
  * @brief  Function implementing the SensorTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartSensorTask */
void StartSensorTask(void *argument)
{
  /* USER CODE BEGIN 5 */
  /* Infinite loop */
  for(;;)
  {
	  if(system_status){
		  float temperature = process_temperature();
	      if(temperature != -1)
	      {
	    	  osMessageQueuePut(tempQueueHandle, &temperature, 0, 0);
	    	  osDelay(1000);
	      }
	  }
  /* USER CODE END 5 */
  }
}

/* USER CODE BEGIN Header_StartControlTask */
/**
* @brief Function implementing the ControlTask thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_StartControlTask */
void StartControlTask(void *argument)
{
    for(;;)
    {
        /* Wait for temperature from SensorTask */
        if(osMessageQueueGet(tempQueueHandle, &temp_rx, NULL, 	osWaitForever) == osOK)
        {
            if(system_status){
				if(temp_rx < 25)
					duty = 20;
				else if(temp_rx <= 30)
					duty = 50;
				else
					duty = 80;
				/* Convert % to CCR value (ARR = 255) */
				fan_percent = (duty * 255) / 100;
				__HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, fan_percent);

				/* Store latest values */
				flash_read_data();
				flash_write_data(temp_rx, duty);
            }
            else{
            	// Stop fan
//            	__HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);
//            	HAL_TIM_PWM_Stop(&htim2, TIM_CHANNEL_1);
            }
        }
//        if(system_status==0){
//        	__HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, zero);
//        	continue;
    }
}
