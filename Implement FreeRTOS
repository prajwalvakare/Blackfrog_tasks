		  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);
		  char msg[] = "STOP fan\r\n";
		  HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);
	  }
}
  /* USER CODE END StartFAN_Stop */
