/**
* @brief Function implementing the StatusTask thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_StartStatusTask */
void StartStatusTask(void *argument)
{
    uint32_t flags;

    for(;;)
    {
        flags = osEventFlagsWait(uartEventHandle,  EVT_SYSTEM_RUN, osFlagsWaitAll | osFlagsNoClear,100);
        if (flags & EVT_SYSTEM_RUN)
        {
            HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
            osDelay(1000);
        }
//        else
//        {
//            HAL_GPIO_WritePin(GPIOC, GPIO_PIN_13, 0); // OFF
//        }
    }
}
